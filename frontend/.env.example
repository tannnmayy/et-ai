# Optional deployed API address. Omit when running locally: Vite proxies /api to FastAPI.
VITE_API_BASE_URL=
# Browser-restricted Google Maps JavaScript API key (required for live map tiles).
# Restart `npm run dev` after changing this. Prefer this file over root .env for Vite.
VITE_GOOGLE_MAPS_API_KEY=
# Optional Cloud Console Map ID for Advanced Markers / cloud styling
# VITE_GOOGLE_MAPS_MAP_ID=
