# Google Maps API Keys (Milestone 5B)
# Browser key (for future frontend): Maps JavaScript API, Places API (New)
GOOGLE_MAPS_BROWSER_API_KEY=
# Server key (for backend): Geocoding API, Routes API
GOOGLE_MAPS_SERVER_API_KEY=

# Copilot LLM — multi-key Gemini fallback (key1 → key2 → key3 on rate limit)
AQI_SENTINEL_LLM_PROVIDER=gemini
AQI_SENTINEL_GEMINI_MODEL=gemini-2.5-flash
AQI_SENTINEL_LLM_MODEL=gemini-2.5-flash
AQI_SENTINEL_GEMINI_API_KEY=your-gemini-api-key-here
AQI_SENTINEL_GEMINI_API_KEY_2=your-second-gemini-api-key-here
AQI_SENTINEL_GEMINI_API_KEY_3=your-third-gemini-api-key-here
# Optional secondary providers if Gemini pool is exhausted
AQI_SENTINEL_OPENROUTER_API_KEY=your-openrouter-api-key-here
AQI_SENTINEL_OPENROUTER_MODEL=openrouter/free
AQI_SENTINEL_LLM_API_KEY=your-groq-api-key-here

# Optional: OpenAQ API Key (for real air quality data)
# OPENAQ_API_KEY=

# Milestone 7 — NASA FIRMS fire detection (free signup at https://firms.modaps.eosdis.nasa.gov/)
# FIRMS_MAP_KEY=

# Milestone 7 — Google Earth Engine service account for Sentinel-5P NO2
# GEE_SERVICE_ACCOUNT_KEY_PATH= 
#FIRMS_MAP_KEY=
#GEE_SERVICE_ACCOUNT_KEY_PATH=
#GEE_PROJECT_ID=
