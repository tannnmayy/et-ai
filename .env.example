# Google Maps API Keys (Milestone 5B)
# Browser key (for future frontend): Maps JavaScript API, Places API (New)
GOOGLE_MAPS_BROWSER_API_KEY=
# Server key (for backend): Geocoding API, Routes API
GOOGLE_MAPS_SERVER_API_KEY=

# Copilot LLM — Phase 1: Groq-primary native tool calling, Gemini fallback
# Preferred provider for text path (tool-calling still tries Groq first when keys exist)
AQI_SENTINEL_LLM_PROVIDER=groq
# Working default on many Groq projects; override if your project enables Llama models
AQI_SENTINEL_GROQ_MODEL=openai/gpt-oss-120b
# Dedicated Groq keys for Copilot (rotate on rate limit)
AQI_SENTINEL_GROQ_API_KEY=your-groq-api-key-here
AQI_SENTINEL_GROQ_API_KEY_2=your-second-groq-api-key-here
# Legacy single Groq key alias (optional)
AQI_SENTINEL_LLM_API_KEY=
# Gemini multi-key fallback (key1 → key2 → key3 on rate limit)
AQI_SENTINEL_GEMINI_MODEL=gemini-2.5-flash
AQI_SENTINEL_LLM_MODEL=gemini-2.5-flash
AQI_SENTINEL_GEMINI_API_KEY=your-gemini-api-key-here
AQI_SENTINEL_GEMINI_API_KEY_2=your-second-gemini-api-key-here
AQI_SENTINEL_GEMINI_API_KEY_3=your-third-gemini-api-key-here
# Optional OpenRouter fallback
AQI_SENTINEL_OPENROUTER_API_KEY=your-openrouter-api-key-here
AQI_SENTINEL_OPENROUTER_MODEL=openrouter/free
# Circuit breaker cooldown seconds after rate-limit
AQI_SENTINEL_LLM_CIRCUIT_COOLDOWN=90

# Copilot dense RAG (sentence-transformers + FAISS)
AQI_SENTINEL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
AQI_SENTINEL_RAG_CHUNK_SIZE=700
AQI_SENTINEL_RAG_CHUNK_OVERLAP=120
AQI_SENTINEL_RAG_CACHE_TTL=600

# Copilot response cache TTLs (seconds) — Phase 2
AQI_SENTINEL_COPILOT_CACHE_TTL=180
AQI_SENTINEL_COPILOT_CACHE_TTL_POLICY=600
AQI_SENTINEL_COPILOT_CACHE_TTL_LIVE=90
AQI_SENTINEL_COPILOT_CACHE_TTL_TOOL=60
# Semantic / synonym-folded cache (1=on, 0=off)
AQI_SENTINEL_COPILOT_SEMANTIC_CACHE=1
AQI_SENTINEL_COPILOT_CACHE_MAX=160
AQI_SENTINEL_COPILOT_TOOL_CACHE_MAX=256

# Optional: OpenAQ API Key (for real air quality data)
# OPENAQ_API_KEY=

# Milestone 7 — NASA FIRMS fire detection (free signup at https://firms.modaps.eosdis.nasa.gov/)
# FIRMS_MAP_KEY=

# Milestone 7 — Google Earth Engine service account for Sentinel-5P NO2
# GEE_SERVICE_ACCOUNT_KEY_PATH= 
#FIRMS_MAP_KEY=
#GEE_SERVICE_ACCOUNT_KEY_PATH=
#GEE_PROJECT_ID=
